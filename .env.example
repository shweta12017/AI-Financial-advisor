# Environment configuration for AI Financial Advisor
# Copy this file to .env and fill in the values locally
# IMPORTANT: Never commit your real .env file or API keys to source control

# Required: Gemini API key for calling Google Gemini 2.0 Flash
# Get your key from: https://aistudio.google.com/app/apikey
# For deployment on Render, add this as an environment variable
GEMINI_API_KEY=your_api_key_here

# Optional: override the default Gemini model
# If omitted, the app uses "gemini-2.0-flash"
GEMINI_MODEL=gemini-2.0-flash

# Deployment Notes:
# - Local: Copy this file to .env and add your API key
# - Render: Add GEMINI_API_KEY as environment variable in Render dashboard
# - The app works in offline mode even without an API key
# - Your API key is protected by .gitignore and never committed

